 0000				        .code

				;**************************************************************
				;
				; OUTPUT PRINTER BYTE
				;
				; Outputs a single byte to the paralell printer port via the
				; BIOS call.
				;
				; procedure putprt(b: byte)
				;
				;**************************************************************

 0000				putprt  proc    syscall b: byte
 0003  B4 00			        mov     ah,0
 0005  8A 45 08			        mov     al,b
 0008  66| BA 0000		        mov     dx,0
 000C  CD 17			        int     17h
				        ret
 0010				putprt  endp

				        end
