  570                     name:     butstr;  { filename }
  571                     schema:   shtptr;  { schematic sheet }
  572                     symbol:   shtptr;  { symbol sheet }
  573                     layout:   shtptr;  { layout sheet }
  574                     simulate: shtptr;  { simulate sheet }
  575                     ref:      boolean; { used during external loads }
  576                     cross:    celptr;  { used during external loads }
  577                     next:     celptr   { next entry }
  578   
  579                  end;
  580        csvptr = ^csvrec; { cell save record pointer }
  581        csvrec = record { cell save record }
  582   
  583                    cp: celptr; { cell }
  584                    next: csvptr { next }
  585   
  586                 end;
  587        busety = record { bus entry }
  588   
  589                    name: butstr;  { bus name }
  590                    tmp:  boolean; { bus name is a temp }
  591                    nl:   nodptr;  { nodes chain pointer }
  592                    bl:   drwptr;  { bus lines pointer }
  593                    sl:   busptr;  { used for bus smashing }
  594                    next: busptr   { next entry }
  595   
  596                 end;
  597        nodety = record { node entry }
  598   
  599                    name: butstr;  { node name }
  600                    nord: byte;    { node ordinal }
  601                    tmp:  boolean; { node name is a temp }
  602                    nl:   drwptr;  { first wire in node set }
  603                    sl:   nodptr;  { used for node smashing }
  604                    bl:   nodptr;  { bus membership linkage }
  605                    bh:   busptr;  { bus entry head }
  606                    next: nodptr   { next node in list }
  607   
  608                 end;
  609        drwety = record { drawing entry }
  610                    
  611                    cl:     color;   { color }
  612                    rm:     rotmod;  { rotation mode }
  613                    next:   drwptr;   { next entry }
  614                    case typ: figtyp of { figure type }
  615   
  616                       tend:      ();
  617                       tline, 
  618                       tbline:    (l:  region); { line }
  619                       tbox, 
  620                       tbbox,
  621                       tmet1,
  622                       tmet2,
  623                       tpoly,
  624                       tvia,
  625                       tndiff,
  626                       tpdiff,
  627                       tnwell,
  628                       tpwell,
  629                       tccut:     (b:  region); { rectangle }
  630                       tinter:    ( { intersection }
  631   
  632                          ir: region;  { region }
  633                          itt: figtyp; { type of top layer }
  634                          ipt: drwptr; { pointer to top layer }
  635                          itb: figtyp; { type of bottom layer }
  636                          ipb: drwptr  { pointer to bottom layer }
  637   
  638                       );
  639                       tarc:      (a:  sarc);   { arc/circle }
  640                       tchar:     (c:  chars);  { character string }
  641                       tbus:      (bs: busfig); { bus }
  642                       tcell:     (cr: celref); { subcell reference }
  643                       tnmos, 
  644                       tpmos, 
  645                       tcap, 
  646                       tres, 
  647                       tdiode, 
  648                       tvdd, 
  649                       tvss:      (o:  point); { fixed cell origin }
  650                       twire,
  651                       tjunction,
  652                       tconnect:  ( { node list types }
  653   
  654                          nl: drwptr; { list link for wires in node }
  655                          nh: nodptr;  { link to attached node }
  656                          case figtyp of { node entries }
  657   
  658                             tend, tline, tbox, tarc, tchar, tbus, 
  659                             tbline, tbbox, tcell, tnmos, tpmos, tcap, 
  660                             tres, tdiode, tvdd, tvss: ();
  661                             twire: (w: region);
  662                             tjunction,
  663                             tconnect: (j: point)
  664   
  665                          { end }
  666   
  667                       )
  668   
  669                    { end }
  670   
  671                 end;
  672        namrec = record { name/ordinal save entry }
  673   
  674                    name: butstr;  { name }
  675                    nord: byte;    { ordinal }
  676                    tmp:  boolean; { is a temp }
  677                    next: namptr   { next entry }
  678   
  679                 end;
  680        { printer output buffer }
  681        prtarr = array [0..pbxmax, 0..pbymax] of color;
  682        prtrec = record { printer parameter save record }
  683   
  684                    mx:  rpoint; { maximum }
  685                    off: rpoint; { offset }
  686                    a:   boolean { active flag }
  687   
  688                 end;
  689        prtinx = 1..prtmax; { index for viewer array }
  690        ptrarr = array [prtinx] of prtrec;
  691        { Puck control section.
  692          The puck control record contains all the data 
  693          required to determine the complete puck status.
  694          It is updated each time the tablet is queryed.
  695          The current location of the puck, its valid/invalid
  696          status (puck in proimity of tablet), and the status
  697          of all puck buttons is kept. In addition, serveral
  698          communications flags are kept, which are set by the
  699          puck routine, and cleared only by external software.
  700          These flags indicate puck movement, button assertion,
  701          button deassertion, button drag, and the puck location
  702          at assertion or deassertion. }
  703        pckbut = record { puck button control record }
  704   
  705                    s:  boolean; { current switch close status }
  706                    l:  boolean; { last switch close status }
  707                    a:  boolean; { assertion flag (CMF) }
  708                    d:  boolean; { deassertion flag (CMF) }
  709                    dg: boolean; { drag flag }
  710                    ap: wpoint; { assertion location }
  711                    dp: wpoint  { deassertion location }
  712   
  713                 end;
  714        pckinx = 1..4; { index for puck buttons }
  715        pckctl = record { puck control record }
  716   
  717                    b:  array [pckinx] of pckbut; { puck buttons }
  718                    cl: wpoint; { current location of puck }
  719                    ol: wpoint; { last location of puck }
  720                    m:  boolean; { puck movement flag (CMF) }
  721                    v:  boolean  { puck valid flag }
  722   
  723                 end;
  724        { device errors }
  725        devcod = (deptr); 
  726        bytfil = file of byte; { byte file }
  727   
  728   common
  729   
  730      clrbuf: array [color, { color to be translated }
  731                     1..4,  { layer, yellow, magenta, 
  732                              cyan, black }
  733                     1..2]  { odd/even word }
  734                     of integer;
  735   {}
  736   {**************************************************************
  737   
  738   OUTPUT PRINTER BYTE
  739   
  740   Outputs a single byte to the paralell printer port via the
  741   BIOS call.
  742   
  743   **************************************************************}
  744   
  745   procedure putprt(b: byte);
  746   
  747   var irs: intregspec; { dos call record }
  748   
  749 + begin
  750 + 
  751 *    irs.ah := 00; 
  752 *    irs.dx := 0;
  753 *    irs.al := b;
  754 *    syscall(23, irs) { execute }
  755 + 
  756 + end;
  757 + {}
  758 + {**************************************************************
  759 + 
  760 + INITALIZE PRINTER
  761 + 
  762 + Sets up the basic printer parameters.
  763 + 
  764 + **************************************************************}
  765 + 
  766   procedure iniprt(var ptrmax: rpoint;  { printer maximum (meters) } 
  767                    var ptrdpm: real;    { printer dots per meter }
  768                    var pmax:   wpoint;  { printer buffer maximums }
  769                    var ptrdl:  byte);   { dither limit }
  770   
  771 + begin
  772 + 
  773 +    { set dementions of Fujisu DL3400 printer buffer (13.6in) }
  774 + 
  775 *    ptrmax.x := (13.6*2.54)*0.01; { width of printer path (inches/meters) }
  776 *    ptrmax.y := (11.0*2.54)*0.01; { length of printer path (inch/meter) }
  777 *    ptrdpm := (180.0/2.54)*100.0; { dots per inch/centimeter }
  778 +    { total dots x, actually recalculated at the start of print }
  779 *    pmax.x := round(ptrmax.x*ptrdpm)-1; 
  780 *    pmax.y := 23; { length of 24 wire print swath }
  781 + 
  782 +    { define color equivalences }
  783 + 
  784 *    clrbuf[black, 1, 1]    := 0000000h; { black }
  785 *    clrbuf[black, 1, 2]    := 0000000h;
  786 *    clrbuf[black, 2, 1]    := 0000000h;
  787 *    clrbuf[black, 2, 2]    := 0000000h;
  788 *    clrbuf[black, 3, 1]    := 0000000h;
  789 *    clrbuf[black, 3, 2]    := 0000000h;
  790 *    clrbuf[black, 4, 1]    := 0ffffffh;
  791 *    clrbuf[black, 4, 2]    := 0ffffffh;
  792 + 
  793 *    clrbuf[blue, 1, 1]     := 0000000h; { blue }
  794 *    clrbuf[blue, 1, 2]     := 0000000h;
  795 *    clrbuf[blue, 2, 1]     := 0000000h;
  796 *    clrbuf[blue, 2, 2]     := 0aaaaaah;
  797 *    clrbuf[blue, 3, 1]     := 0555555h;
  798 *    clrbuf[blue, 3, 2]     := 0000000h;
  799 *    clrbuf[blue, 4, 1]     := 0aaaaaah;
  800 *    clrbuf[blue, 4, 2]     := 0555555h;
  801 + 
  802 *    clrbuf[green, 1, 1]    := 0555555h; { green }
  803 *    clrbuf[green, 1, 2]    := 0000000h;
  804 *    clrbuf[green, 2, 1]    := 0000000h;
  805 *    clrbuf[green, 2, 2]    := 0000000h;
  806 *    clrbuf[green, 3, 1]    := 0000000h;
  807 *    clrbuf[green, 3, 2]    := 0aaaaaah;
  808 *    clrbuf[green, 4, 1]    := 0aaaaaah;
  809 *    clrbuf[green, 4, 2]    := 0555555h;
  810 + 
  811 *    clrbuf[cyan, 1, 1]     := 0000000h; { cyan }
  812 *    clrbuf[cyan, 1, 2]     := 0000000h;
  813 *    clrbuf[cyan, 2, 1]     := 0000000h;
  814 *    clrbuf[cyan, 2, 2]     := 0000000h;
  815 *    clrbuf[cyan, 3, 1]     := 0555555h;
  816 *    clrbuf[cyan, 3, 2]     := 0aaaaaah;
  817 *    clrbuf[cyan, 4, 1]     := 0aaaaaah;
  818 *    clrbuf[cyan, 4, 2]     := 0555555h;
  819 + 
  820 *    clrbuf[red, 1, 1]      := 0555555h; { red }
  821 *    clrbuf[red, 1, 2]      := 0000000h;
  822 *    clrbuf[red, 2, 1]      := 0000000h;
  823 *    clrbuf[red, 2, 2]      := 0aaaaaah;
  824 *    clrbuf[red, 3, 1]      := 0000000h;
  825 *    clrbuf[red, 3, 2]      := 0000000h;
  826 *    clrbuf[red, 4, 1]      := 0aaaaaah;
  827 *    clrbuf[red, 4, 2]      := 0555555h;
  828 + 
  829 *    clrbuf[magenta, 1, 1]  := 0000000h; { magenta }
  830 *    clrbuf[magenta, 1, 2]  := 0000000h;
  831 *    clrbuf[magenta, 2, 1]  := 0555555h;
  832 *    clrbuf[magenta, 2, 2]  := 0aaaaaah;
  833 *    clrbuf[magenta, 3, 1]  := 0000000h;
  834 *    clrbuf[magenta, 3, 2]  := 0000000h;
  835 *    clrbuf[magenta, 4, 1]  := 0aaaaaah;
  836 *    clrbuf[magenta, 4, 2]  := 0555555h;
  837 + 
  838 *    clrbuf[brown, 1, 1]    := 0555555h; { brown }
  839 *    clrbuf[brown, 1, 2]    := 0aaaaaah;
  840 *    clrbuf[brown, 2, 1]    := 0000000h;
  841 *    clrbuf[brown, 2, 2]    := 0000000h;
  842 *    clrbuf[brown, 3, 1]    := 0000000h;
  843 *    clrbuf[brown, 3, 2]    := 0000000h;
  844 *    clrbuf[brown, 4, 1]    := 0aaaaaah;
  845 *    clrbuf[brown, 4, 2]    := 0555555h;
  846 + 
  847 *    clrbuf[dwhite, 1, 1]   := 0000000h; { dwhite }
  848 *    clrbuf[dwhite, 1, 2]   := 0000000h;
  849 *    clrbuf[dwhite, 2, 1]   := 0000000h;
  850 *    clrbuf[dwhite, 2, 2]   := 0000000h;
  851 *    clrbuf[dwhite, 3, 1]   := 0000000h;
  852 *    clrbuf[dwhite, 3, 2]   := 0000000h;
  853 *    clrbuf[dwhite, 4, 1]   := 0aaaaaah;
  854 *    clrbuf[dwhite, 4, 2]   := 0000000h;
  855 + 
  856 *    clrbuf[gray, 1, 1]     := 0000000h; { gray }
  857 *    clrbuf[gray, 1, 2]     := 0000000h;
  858 *    clrbuf[gray, 2, 1]     := 0000000h;
  859 *    clrbuf[gray, 2, 2]     := 0000000h;
  860 *    clrbuf[gray, 3, 1]     := 0000000h;
  861 *    clrbuf[gray, 3, 2]     := 0000000h;
  862 *    clrbuf[gray, 4, 1]     := 0aaaaaah;
  863 *    clrbuf[gray, 4, 2]     := 0555555h;
  864 + 
  865 *    clrbuf[lblue, 1, 1]    := 0000000h; { lblue }
  866 *    clrbuf[lblue, 1, 2]    := 0000000h;
  867 *    clrbuf[lblue, 2, 1]    := 0aaaaaah;
  868 *    clrbuf[lblue, 2, 2]    := 0555555h;
  869 *    clrbuf[lblue, 3, 1]    := 0555555h;
  870 *    clrbuf[lblue, 3, 2]    := 0aaaaaah;
  871 *    clrbuf[lblue, 4, 1]    := 0000000h;
  872 *    clrbuf[lblue, 4, 2]    := 0000000h;
  873 + 
  874 *    clrbuf[lgreen, 1, 1]   := 0aaaaaah; { lgreen }
  875 *    clrbuf[lgreen, 1, 2]   := 0555555h;
  876 *    clrbuf[lgreen, 2, 1]   := 0000000h;
  877 *    clrbuf[lgreen, 2, 2]   := 0000000h;
  878 *    clrbuf[lgreen, 3, 1]   := 0555555h;
  879 *    clrbuf[lgreen, 3, 2]   := 0aaaaaah;
  880 *    clrbuf[lgreen, 4, 1]   := 0000000h;
  881 *    clrbuf[lgreen, 4, 2]   := 0000000h;
  882 + 
  883 *    clrbuf[lcyan, 1, 1]    := 0000000h; { lcyan }
  884 *    clrbuf[lcyan, 1, 2]    := 0000000h;
  885 *    clrbuf[lcyan, 2, 1]    := 0000000h;
  886 *    clrbuf[lcyan, 2, 2]    := 0000000h;
  887 *    clrbuf[lcyan, 3, 1]    := 0ffffffh;
  888 *    clrbuf[lcyan, 3, 2]    := 0ffffffh;
  889 *    clrbuf[lcyan, 4, 1]    := 0000000h;
  890 *    clrbuf[lcyan, 4, 2]    := 0000000h;
  891 + 
  892 *    clrbuf[lred, 1, 1]     := 0aaaaaah; { lred }
  893 *    clrbuf[lred, 1, 2]     := 0555555h;
  894 *    clrbuf[lred, 2, 1]     := 0555555h;
  895 *    clrbuf[lred, 2, 2]     := 0aaaaaah;
  896 *    clrbuf[lred, 3, 1]     := 0000000h;
  897 *    clrbuf[lred, 3, 2]     := 0000000h;
  898 *    clrbuf[lred, 4, 1]     := 0000000h;
  899 *    clrbuf[lred, 4, 2]     := 0000000h;
  900 + 
  901 *    clrbuf[lmagenta, 1, 1] := 0000000h; { lmagenta }
  902 *    clrbuf[lmagenta, 1, 2] := 0000000h;
  903 *    clrbuf[lmagenta, 2, 1] := 0ffffffh;
  904 *    clrbuf[lmagenta, 2, 2] := 0ffffffh;
  905 *    clrbuf[lmagenta, 3, 1] := 0000000h;
  906 *    clrbuf[lmagenta, 3, 2] := 0000000h;
  907 *    clrbuf[lmagenta, 4, 1] := 0000000h;
  908 *    clrbuf[lmagenta, 4, 2] := 0000000h;
  909 + 
  910 *    clrbuf[yellow, 1, 1]   := 0ffffffh; { yellow }
  911 *    clrbuf[yellow, 1, 2]   := 0ffffffh;
  912 *    clrbuf[yellow, 2, 1]   := 0000000h;
  913 *    clrbuf[yellow, 2, 2]   := 0000000h;
  914 *    clrbuf[yellow, 3, 1]   := 0000000h;
  915 *    clrbuf[yellow, 3, 2]   := 0000000h;
  916 *    clrbuf[yellow, 4, 1]   := 0000000h;
  917 *    clrbuf[yellow, 4, 2]   := 0000000h;
  918 + 
  919 *    clrbuf[white, 1, 1]    := 0000000h; { white }
  920 *    clrbuf[white, 1, 2]    := 0000000h;
  921 *    clrbuf[white, 2, 1]    := 0000000h;
  922 *    clrbuf[white, 2, 2]    := 0000000h;
  923 *    clrbuf[white, 3, 1]    := 0000000h;
  924 *    clrbuf[white, 3, 2]    := 0000000h;
  925 *    clrbuf[white, 4, 1]    := 0000000h;
  926 *    clrbuf[white, 4, 2]    := 0000000h
  927 + 
  928 + end;
  929 + {}
  930 + {**************************************************************
  931 + 
  932 + PREPARE PRINTER FOR OUTPUT
  933 + 
  934 + Resets and initalizes the printer for output. This is done
  935 + before printout to insure that the printer has not just
  936 + been turned on.
  937 + 
  938 + **************************************************************}
  939 + 
  940   procedure strprt;
  941   
  942 + begin
  943 + 
  944 *    putprt(27); { reset printer }
  945 *    putprt(26);
  946 *    putprt(73);
  947 +  
  948 *    putprt(27); { set print direction unidirectional }
  949 *    putprt(85);
  950 *    putprt(01)
  951 + 
  952 + end;
  953 + {}
  954 + {**************************************************************
  955 + 
  956 + OUTPUT PRINTER BUFFER
  957 + 
  958 + Load the printer assembly buffer into the printer output
  959 + buffer, then outputs the buffer.
  960 + Dependant on the fujisu DL3400 printer.
  961 + Presently only black and white are supported (any color but
  962 + white is printed as black).
  963 + 
  964 + **************************************************************}
  965 + 
  966   procedure outbuf(var prtbuf: prtarr; pmaxx: word);
  967   
  968   type clr = 1..4; { printer ribbon color, yellow, magenta,
  969                      cyan and black }
  970   
  971   var linbuf: array [1..2520] of integer; { graphic line buffer }
  972       blank: boolean; { blank line flag }
  973   
  974   { output printer graphics line }
  975   
  976   procedure outlin(l: integer; c: clr);
  977   
  978   var i: 1..2048;
  979   
  980 + begin
  981 + 
  982 *    putprt(27); { set color of line }
  983 *    putprt(114);
  984 *    case c of { color }
  985 + 
  986 *       1: putprt(4); { yellow }
  987 *       2: putprt(1); { magenta }
  988 *       3: putprt(2); { cyan }
  989 *       4: putprt(0)  { black }
  990 + 
  991 +    end;
  992 *    putprt(13); { return to line start }
  993 *    putprt(27); { output line preamble }
  994 *    putprt(42);
  995 *    putprt(39);
  996 *    putprt(l mod 256); { number of 24 bit words }
  997 *    putprt(l div 256);
  998 *    for i := 1 to l do begin { output graphic line }
  999 + 
 1000 +       { output screen data }
 1001 *       putprt(linbuf[i] div 65536);
 1002 *       putprt((linbuf[i] div 256) mod 256); 
 1003 *       putprt(linbuf[i] mod 256); 
 1004 + 
 1005 *    end;
 1006 *    putprt(13); { return to line start }
 1007 + 
 1008 * end;
 1009 + 
 1010   procedure plclin(c: clr; var blank: boolean);
 1011   
 1012   var i: 1..2048;
 1013       p: integer;
 1014       b: integer;
 1015       x, y: word;
 1016   
 1017 + begin
 1018 + 
 1019 *    blank := true; { set line blank }
 1020 *    i := 1; { initalize index }
 1021 +    { translate buffer }
 1022 *    for x := 0 to pmaxx do begin
 1023 + 
 1024 *       p := 0; { clear output pattern }
 1025 *       b := 0800000h; { set bit mask }
 1026 *       for y := 0 to 23 { pmax.y } do begin 
 1027 + 
 1028 *          p := p+(clrbuf[prtbuf[x, y], c, ord(odd(x))+1] and b);
 1029 *          b := b div 2 { next bit }
 1030 + 
 1031 +       end;   
 1032 *       linbuf[i] := p; { place data }
 1033 *       i := i + 1; { next }
 1034 *       if p <> 0 then blank := false { set line not blank }
 1035 + 
 1036 +    end
 1037 + 
 1038 + end;
 1039 + 
 1040 + begin
 1041 + 
 1042 +    { do each of the 4 primaries as a separate pass }
 1043 + 
 1044 +    { yellow }
 1045 *    plclin(1, blank); { place line into buffer }
 1046 *    if not blank then outlin(pmaxx+1, 1); { output graphic line }
 1047 +    { magenta }
 1048 *    plclin(2, blank);
 1049 *    if not blank then outlin(pmaxx+1, 2); 
 1050 +    { cyan }
 1051 *    plclin(3, blank); 
 1052 *    if not blank then outlin(pmaxx+1, 3); 
 1053 +    { black }
 1054 *    plclin(4, blank); 
 1055 *    if not blank then outlin(pmaxx+1, 4);
 1056 +    { move to next line }
 1057 *    putprt(27); putprt(74); putprt(24)
 1058 + 
 1059 + end;
 1060 + {}
 1061 + {**************************************************************
 1062 + 
 1063 + INCREMENT IN Y DIRECTION
 1064 + 
 1065 + Spaces N*180/in in Y for the Fujisu DL3400 printer.
 1066 + Note: uses single increment mode, that is rather slow.
 1067 + Problems were found with arbitrary values in the increment
 1068 + command.
 1069 + 
 1070 + **************************************************************}
 1071 + 
 1072   procedure offy(c: integer);
 1073   
 1074   var i: integer;
 1075   
 1076 + begin
 1077 + 
 1078 +    { move to next line }
 1079 *    for i := 1 to c do 
 1080 *       begin putprt(27); putprt(74); putprt(1) end
 1081 + 
 1082 + end;
 1083 + {}
 1084 + {**************************************************************
 1085 + 
 1086 + OUTPUT PRINTER PAGE
 1087 + 
 1088 + Brings the printer to the next page position.
 1089 + 
 1090 + **************************************************************}
 1091 + 
 1092   procedure pagprt;
 1093   
 1094 + begin
 1095 + 
 1096 *    putprt(12) { next page }
 1097 + 
 1098 + end;
 1099 + {}
 1100 + begin
 1101 * end.
