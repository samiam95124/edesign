  467        butrec =  record { button descriptors }
  468   
  469                     x, y:   byte;     { address of button origin }
  470                     x1, y1,
  471                     x2, y2: word;     { screen bounding address }
  472                     s:      butstr;   { button string }
  473                     l:      btsinx;   { length of string }
  474                     act:    boolean;  { button active }
  475                     sel:    boolean;  { button selected }
  476                     dis:    boolean;  { button disabled }
  477                     man:    boolean;  { button is manually selected }
  478                     alt:    boolean;  { button on alert }
  479                     sm:     modset;   { applicable screen mode }
  480                     acf:    color;    { "active" color foreground }
  481                     acb:    color;    { "active" color background }
  482                     icf:    color;    { "inactive" color foreground }
  483                     icb:    color    { "inactive" color backround }
