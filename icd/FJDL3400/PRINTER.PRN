  171         aminy     = 129;
  172         amaxx     = 894;
  173         amaxy     = 767;
  174         tgminx    = 897;   { demensions of target display }
  175         tgminy    = 0;
  176         tgmaxx    = 1023;
  177         tgmaxy    = 126;
  178         tgborder  = 5;     { target border space }
  179         pi        = 3.141592653589793;
  180         linmax    = 10000; { maximum length of screen line }
  181         scalem    = 100;   { scale accuracy multiplier }
  182         dotmin    = 8;     { minimum grid dot spacing to display dot grid }
  183         linemin   = 8;     { minimum grid dot spacing to display line grid }
  184         normscale = 300;   { normal magnification scale }
  185         bbborder  = 10;    { bounding box default border }
