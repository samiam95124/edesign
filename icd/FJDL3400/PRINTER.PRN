  187         msglen    = 35;    { number of characters in a message }
  188         dragmgn   = 10;    { number of pixels to consitute a drag }
  189         dotmax    = 1024;  { number of dots in a vector }
  190         chrwdt    = 4;     { width factor of vector character }
  191         chrhdt    = 11;    { height factor of vector character }
  192         chrspc    = 2;     { space between vector characters }
  193         dftsiz    = 0.000001; { default size of virtual pixel (meters) }
  194         dftsizl   = 0.000000001; { same for layout only }
  195         dftchr    = 300;   { default size of vector character (in virtual
  196                              pixels) }
  197         dftdg     = 1500; { default dot grid spacing (in vpixels) }
  198         dftlg     = 30000; { default line grid spacing (in vpixels) }
  199         dftjun    = 750; { default size of junction (in vpixels) }
  200         dftcon    = 1000; { default size of connector (in vpixels) }
