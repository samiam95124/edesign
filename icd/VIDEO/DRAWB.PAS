module drawb;

uses {$U ..\common.j} common;

var alpha: packed array[0..127, 1..16, 1..16] of char;

{ set pixel value }
procedure rsetpix(x, y: integer; c: color); external;
{ convert x screen coordinate }
procedure viewx(var vp: viewport; var x: integer); external;
{ convert y screen coordinate }
procedure viewy(var vp: viewport; var y: integer); external;
{}
{**************************************************************

SET CHARACTER

Draws a single character, from a 16 by 16 source block.
Accepts real coordinates, and clips.

***************************************************************}

procedure setchr(vp:   viewport; { viewport }
                 x, y: integer; { address of origin }
                 ch:   char;    { character to place }
                 cl:   color);  { foreground color }

var ix, iy: integer; { index }

begin

   viewx(vp, x); { find screen coordinates }
   viewy(vp, y);
   for iy := 0 to 15 do { rows }
      for ix := 0 to 15 do { collumns }   
      { set pixel with proper color }
      if (alpha[ord(ch), iy+1, ix+1] = '1') and
         (ix+x >= vp.c.s.x) and (ix+x <= vp.c.e.x) and
         (iy+y >= vp.c.s.y) and (ix+y <= vp.c.e.y) then
            rsetpix(ix+x, iy+y, cl) { foreground }

end;
