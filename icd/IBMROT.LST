 004F				clrint  proc    syscall
 004F  FA			        cli                     ; clear interupt flag
 0050  C3			        ret                     ; exit
 0051				clrint  endp

				;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;
				;                                                             ;
				; CLEAR INTERRUPT FLAG                                        ;
				;                                                             ;
				; Clears the interrupt enable flag. Used to disable           ;
				; interrupts.                                                 ;
				;                                                             ;
				;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;

 0051				setint  proc    syscall
 0051  FB			        sti                     ; set interupt flag
 0052  C3			        ret                     ; exit
 0053				setint  endp

				        end
