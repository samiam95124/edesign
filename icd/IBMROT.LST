				;                                                             ;
				; Clears the interrupt enable flag. Used to disable           ;
				; interrupts.                                                 ;
				;                                                             ;
				;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;
Microsoft (R) Macro Assembler Version 6.00     		    02/02/94 10:15:29
