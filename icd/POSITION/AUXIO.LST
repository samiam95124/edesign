				                title   'pointer device access routines'
				                name    auxio
				                page    55,132

 = 03F8				comm_data       equ     03f8h           ; port assignments for COM1
 = 03F9				com_ier         equ     03f9h
 = 03FC				comm_mcr        equ     03fch
 = 03FD				comm_stat       equ     03fdh

				        .386
				        .model  small, c

 0000				        .code

				;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;
				;                                                             ;
				; INITALIZE COM1:                                             ;
				;                                                             ;
				; Initalizes COM1: to 9600 baud, 8 bits, odd parity, one      ;
				; stop bit, as required by the Summagraphics tablet.          ;
				; The uart is cleared of any garbage waiting.                 ;
				;                                                             ;
				;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;

 0000				iniaux  proc    syscall
 0000  66| BA 0000		        mov     dx,0            ; set COM1:
 0004  66| B8 00EB		        mov     ax,000ebh       ; set 9600,8,o,1
 0008  CD 14			        int     20              ; initalize port
 000A  C3			        ret                     ; exit
 000B				iniaux  endp

				;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;
				;                                                             ;
				; CHECK STATUS COM1:                                          ;
				;                                                             ;
				; Returns status of character waiting for COM1:. This is      ;
				; 0 if no character awaits, or 0ffh if one is.                ;
				;                                                             ;
				; function stsaux: byte;                                      ;
				;                                                             ;
				;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;

 000B				stsaux  proc    syscall
 000B  66| BA 03FD		        mov     dx,comm_stat    ; index status port
 000F  EC			        in      al,dx           ; get status
 0010  66| 83 E0 01		        and     ax,001h         ; mask
 0014  74 04			        jz      stsaux01        ; not ready, exit
 0016  66| B8 00FF		        mov     ax,0ffh         ; else set ready code
 001A				stsaux01:
 001A  C3			        ret
 001B				stsaux  endp

				;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;
				;                                                             ;
				; INPUT COM1:                                                 ;
				;                                                             ;
				; Inputs a single character from COM1:.                       ;
Microsoft (R) Macro Assembler Version 6.00     		    03/19/92 11:44:34
'pointer device access routines'			     Page 2 - 1


				; Features a timeout to insure that this routine will not     ;
				; hangup. There is no error indication for this.              ;
				;                                                             ;
				; function getaux: byte;                                      ;
				;                                                             ;
				;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;

 001B				getaux  proc    syscall
 001B  53			        push    ebx             ; save registers used
 001C  66| BB 2710		        mov     bx,10000        ; set timeout value
 0020  66| BA 03FD		        mov     dx,comm_stat    ; index status port
 0024				getaux01:
 0024  EC			        in      al,dx           ; get status
 0025  24 01			        and     al,001h         ; mask
 0027  75 08			        jnz     getaux02        ; ready, skip
 0029  66| 4B			        dec     bx              ; process timeout
 002B  8A C3			        mov     al,bl           ; check timeout occurred
 002D  0A C7			        or      al,bh
 002F  75 F3			        jnz     getaux01        ; no, loop
 0031				getaux02:
 0031  66| BA 03F8		        mov     dx,comm_data    ; index data port
 0035  EC			        in      al,dx           ; get byte      
 0036  66| 0F B6 C0		        movzx   ax,al           ; extend to word
 003A  5B			        pop     ebx             ; restore registers
 003B  C3			        ret
 003C				getaux  endp

				;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;
				;                                                             ;
				; OUTPUT COM1:                                                ;
				;                                                             ;
				; Outputs a single byte to the COM1: port.                    ;
				;                                                             ;
				; procedure putaux(b: byte);                                  ;
				;                                                             ;
				;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;

 003C				putaux  proc    syscall b: byte
 003F  66| BA 03FD		        mov     dx,comm_stat    ; index status port
 0043				putaux01:
 0043  EC			        in      al,dx           ; get status
 0044  24 20			        and     al,020h         ; mask
 0046  74 FB			        jz      putaux01        ; loop till ready
 0048  8A 45 08			        mov     al,b            ; get byte to output
 004B  66| BA 03F8		        mov     dx,comm_data    ; index data port
 004F  EE			        out     dx,al           ; output byte
				        ret                     ; exit
 0052				putaux  endp

				;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;
				;                                                             ;
