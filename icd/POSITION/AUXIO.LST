				; INITALIZE MOUSE DRIVER                                      ;
				;                                                             ;
				; procedure inims; cexternal;                                 ;
				;                                                             ;
				;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;

 0052				inims   proc    syscall
 0052  66| B8 0000		        mov     ax,00000h       ; reset mouse and get status
 0056  CD 33			        int     33h             ; execute
 0058  C3			        ret                     ; exit
 0059				inims   endp

				;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;
				;                                                             ;
				; READ MOTION COUNTERS                                        ;
				;                                                             ;
				; procedure readmot(var x, y: integer); cexternal;            ;
				;                                                             ;
				;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;

 = 0008				motx    =       8
 = 000C				moty    =       12

 0059				readmot proc    syscall
 0059  55			        push    ebp             ; link parameters
 005A  8B EC			        mov     ebp,esp
 005C  53			        push    ebx             ; preserve caller registers
 005D  66| B8 000B		        mov     ax,0000bh       ; read motion counters
 0061  CD 33			        int     33h             ; execute
 0063  0F BF C9			        movsx   ecx,cx          ; extend x
 0066  0F BF D2			        movsx   edx,dx          ; extend y
 0069  8B 5D 08			        mov     ebx,[ebp+motx]  ; get address of x
 006C  89 0B			        mov     [ebx],ecx       ; place
 006E  8B 5D 0C			        mov     ebx,[ebp+moty]  ; get address of y
 0071  89 13			        mov     [ebx],edx       ; place
 0073  5B			        pop     ebx             ; restore registers and return
 0074  5D			        pop     ebp             ; unlink
 0075  C3			        ret
 0076				readmot endp

				;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;
				;                                                             ;
				; READ BUTTON STATUS                                          ;
				;                                                             ;
				; Reads the current button press status.                      ;
				;                                                             ;
				;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;

 0076				readsts proc    syscall
 0076  66| B8 0003		        mov     ax,00003h       ; get mouse button status
 007A  CD 33			        int     33h             ; execute
