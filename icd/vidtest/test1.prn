  149   const maxx      = 1023;  { demensions of standard screen }
  150         maxy      = 767;
  151         minx      = 0;
  152         miny      = 0;
  153         aminx     = 0;     { demensions of active area }
  154         aminy     = 129;
  155         amaxx     = 894;
  156         amaxy     = 767;
  157         tgminx    = 897;   { demensions of target display }
  158         tgminy    = 0;
  159         tgmaxx    = 1023;
  160         tgmaxy    = 126;
  161         tgborder  = 5;     { target border space }
  162         pi        = 3.141592653589793;
  163         linmax    = 10000; { maximum length of screen line }
  164         scalem    = 100;   { scale accuracy multiplier }
  165         dotmin    = 8;     { minimum grid dot spacing to display dot grid }
  166         linemin   = 8;     { minimum grid dot spacing to display line grid }
  167         normscale = 300;   { normal magnification scale }
  168         bbborder  = 10;    { bounding box default border }
  169         butlen    = 8;     { number of characters in a button }
  170         msglen    = 35;    { number of characters in a message }
  171         dragmgn   = 10;    { number of pixels to consitute a drag }
  172         dotmax    = 1024;  { number of dots in a vector }
  173         chrwdt    = 4;     { width factor of vector character }
  174         chrhdt    = 11;    { height factor of vector character }
  175         chrspc    = 2;     { space between vector characters }
  176         dftsiz    = 0.000001; { default size of virtual pixel (meters) }
  177         dftsizl   = 0.000000001; { same for layout only }
  178         dftchr    = 300;   { default size of vector character (in virtual
  179                              pixels) }
  180         dftdg     = 1500; { default dot grid spacing (in vpixels) }
  181         dftlg     = 30000; { default line grid spacing (in vpixels) }
  182         dftjun    = 750; { default size of junction (in vpixels) }
  183         dftcon    = 1000; { default size of connector (in vpixels) }
  184         viewmax   = 8; { number of stored views }
  185         sizemax   = 8; { number of stored text sizes }
  186         blkmax    = 8; { number of stored blocks }
  187         prtmax    = 8; { number of printer parameter saves }
  188         { special character definitions }
  189         copychr   = 0; { copright character }
  190         microchr  = 1; { micro character }
  191         selrng    = 5; { range to be within to select object
  192                          (in screen pixels) }
  193         { printer buffer dementions. These are set to the maximum of
  194           the dementions of any printer we support. 
  195           Presently, exactly one line is contained, based on the
  196           theory that the last line can be printed while the next
  197           line is prepared. }
  198         pbxmax    = 2519;
  199         pbymax    = 23;
  200         timeout   = 300; { number of idle seconds before screen 
  201                            blank (5 min) }
  202         figet     = 3; { figet factor for pointer idle detect }
  203         timesiz   = 0.000000000001; { time value of virtual pixel }
  204         voltsiz   = 0.001666666666; { voltage value of virtual pixel }
  205         trcsiz    = 4800; { height of trace, in virtual pixels }
  206         stpsiz    = 1000; { length of trace step }
  207     
  208   type color  = (black, blue, green, cyan, red, magenta, brown,
  209                  dwhite, gray, lblue, lgreen, lcyan, lred, lmagenta,
  210                  yellow, white);
  211        point  = record x, y: integer end; { coordinate point }
  212        rpoint = record x, y: real end; { demension pair (meters) }
  213        wpoint = record x, y: word end; { coordinate point (onscreen) }
  214        bpoint = record x, y: byte end; { char cell coordinates }
  215        region = record s, e: point end; { rectangular region }
  216        sarc   = record { arc specification }
  217               
  218                    s: point; { start point }
  219                    e: point; { end point (c-clockwise) }
  220                    c: point; { center }
  221                    r: integer { radius }
  222       
  223                 end;
  224        chrptr = ^chrrec; { character record pointer }
  225        chrrec = record { character record }
  226   
  227                    c:    char; { the character }
  228                    next: chrptr { next entry } 
  229   
  230                 end;
  231        chars  = record { character string specification }
  232   
  233                    r: region;  { enclosure box }
  234                    l: chrptr; { character list start }
  235                    s: integer { character scale }
  236   
  237                 end;
  238        shtptr  = ^shtrec; { sheet record pointer }
  239        celtyp = (ctsch, ctsym, ctlay); { placement cell type }
  240        celref = record { cell subreference }
  241   
  242                    o:  point;  { upper left origin }
  243                    cp: shtptr; { subcell }
  244                    ct: celtyp; { type of cell }
  245   
  246                 end;
  247        nodptr = ^nodety; { node entry pointer }
  248        drwptr = ^drwety; { drawing entry pointer }
  249        namptr = ^namrec; { name save pointer }
  250        btsinx = 1..butlen; { index for button string }
  251        butstr = packed array [btsinx] of char;
  252        msginx = 1..msglen; { index for message string }
  253        msgstr = packed array [msginx] of char;
  254        msgtyp = (mnone,    { none (blank message) }
  255                  minvn,    { invalid number }
  256                  movfn);   { integer overflow }
  257        busptr = ^busety; { bus entry pointer }
