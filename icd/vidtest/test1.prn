   51   FUNCTION ConSilent: char;  external;
   52   
   53   
   54       { -- Date and time -- }
   55   
   56   TYPE  TimeStamp = PACKED RECORD
   57                       DateValid,
   58                       TimeValid: Boolean;
   59                       Year: 1..maxint;
   60                       Month: 1..12;   {January = 1}
   61                       Day: 1..31;
   62                       Hour: 0..23;
   63                       Minute: 0..59;
   64                       Second: 0..59;
   65                       Hund: 0..99;
   66                     END;
   67   
   68   PROCEDURE GetTimeStamp (VAR ts: TimeStamp);  external;
   69   PROCEDURE SetTime (ts: TimeStamp);  external;
   70   PROCEDURE FDate (h: handletype; VAR ts: TimeStamp);  external;
   71   PROCEDURE DateString (ts: TimeStamp; VAR dst: string);  external;
   72   PROCEDURE TimeString (ts: TimeStamp; VAR tst: string);  external;
   73   PROCEDURE Wait (SecsDelay: real);  external;
   74   
   75   
