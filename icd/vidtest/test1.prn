  534   
  535                     l: laylst;              { figure list }
  536                     n: namptr;              { name list }
  537                     sx, sy, ex, ey: integer { bounding box }
  538   
  539                  end;
  540        blkarr  = array [blkinx] of blkrec; { block storage array }
  541        celptr  = ^celrec; { cell record pointer }
  542        shtrec  = record { sheet control record }
  543      
  544                     dl:         laylst; { drawing lists }
  545                     nl:         nodptr; { node list }
  546                     bl:         busptr; { bus list }
  547                     nc:         integer; { node counter }
  548                     vp:         viewport; { viewport for sheet }
  549                     lvp:        viewport; { last viewport for sheet }
  550                     bbsx, bbsy,
  551                     bbex, bbey: integer; { bounding box }
  552                     bs:         boolean; { bounds set flag }
  553                     sbbsx, sbbsy,
  554                     sbbex, sbbey: integer; { symbol bounding box }
  555                     sbs:        boolean; { symbol bounds set flag }
  556                     ds:         integer; { dot grid size }
  557                     ls:         integer; { line grid size }
  558                     js:         integer; { junction size }
  559                     cs:         integer; { connector size }
  560                     ts:         integer; { text size }
  561                     sv:         viewarr; { stored views }
  562                     sts:        sizearr; { stored text sizes }
  563                     sds:        sizearr; { stored dot grid sizes }
  564                     sls:        sizearr; { stored line grid sizes }
  565                     csp:        celptr;  { used during external loads }
  566                     next:       shtptr;  { used during external loads }
  567   
  568                  end;
  569        celrec  = record { cell record }
