  456        butsts =  (unset, inact, act, select, una); { button status }
  457        figtyp = (tend, tline, tbox, tarc, tchar, twire, tbus, 
  458                  tjunction, tbline, tbbox, tcell, tconnect,
  459                  tnmos, tpmos, tcap, tres, tdiode, tvdd, tvss,
  460                  tmet1, tmet2, tpoly, tvia, tndiff, tpdiff,
  461                  tnwell, tpwell, tccut, tinter, tcont, ttrc);
  462        rotmod = (rm0, rm90, rm180, rm270, rmm0, rmm90, rmm180, 
  463                  rmm270);
  464        { screen menu modes }
  465        scnmod = (smsymbol, smschema, smlayout, smsimulate,
  466                  smprint);
  467        modset = set of scnmod; { set of same }
  468        butrec =  record { button descriptors }
  469   
  470                     x, y:   byte;     { address of button origin }
  471                     x1, y1,
  472                     x2, y2: word;     { screen bounding address }
  473                     s:      butstr;   { button string }
  474                     l:      btsinx;   { length of string }
  475                     act:    boolean;  { button active }
  476                     sel:    boolean;  { button selected }
  477                     dis:    boolean;  { button disabled }
  478                     man:    boolean;  { button is manually selected }
  479                     alt:    boolean;  { button on alert }
  480                     sm:     modset;   { applicable screen mode }
  481                     acf:    color;    { "active" color foreground }
  482                     acb:    color;    { "active" color background }
  483                     icf:    color;    { "inactive" color foreground }
  484                     icb:    color    { "inactive" color backround }
  485   
  486                  end;
  487        dotinx =  1..dotmax; { dot vector index }
  488        dotvec =  array[dotinx] of word; { dot vector }
  489        { cell file partition marker codes }
  490        celseg = (ccfterm, ccterm, cceldir, ccell, ccschema, cclayout, 
  491                  ccwave, ccsymbol);
  492        { Viewport specification
  493          A viewport is a complete specification of the parameters
  494          that define a window.  }
  495        viewport = record { viewport parameters, in real }
  496   
  497                      r: region; { viewport rectangle real }
  498                      s: integer; { scale }
  499                      v: region   { viewport rectangle screen }
  500   
  501                   end;     
  502        viewrec = record { view specification }
  503   
  504                     vp:   viewport; { viewport }
  505                     a:    boolean   { view active flag }
  506   
  507                  end;
  508        viewinx = 1..viewmax; { index for viewer array }
  509        viewarr = array [viewinx] of viewrec;
  510        sizerec = record { size specification }
  511   
  512                     s:    integer; { size }
  513                     a:    boolean  { size active flag }
  514   
  515                  end;
  516        sizeinx = 1..sizemax; { index for size array }
  517        sizearr = array [sizeinx] of sizerec;
  518        trcarr  = array [color] of boolean; { trace color tracking }
  519        { layer codes }
  520        laytyp  = (ltcell,  { cells layer }
  521                   ltfig,   { figures layer }
  522                   ltovg,   { overglass layer }
  523                   ltvia,   { via layer }
  524                   ltism2,  { met 2 intersections layer }
