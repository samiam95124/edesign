Pro Pascal Compiler - Version iid 3.1

Compilation of: TEST1.PAS

Options:    LNIPJ2

    1   {**************************************************************
    2   
    3   VIDEO MODE TEST
    4   
    5   Tests if the pixel read/write routines work in all resolutions
    6   (not all cards implement them for all modes). Must be customized
    7   per the card.
    8   
    9   **************************************************************}
   10   
   11   program test1;
   12   
   13   {$i ..\define}
   14   {$i c:\propas\doslib}
   15       { Declarations for Pro Pascal DOSLIB }
   16   
   17   
   18       { -- General items -- }
   19   
   20   TYPE  DOSName = string[76];
   21         HandleType = -1..99;
   22           {file attributes}
   23         Attribute = (AttrReadOnly, AttrHidden, AttrSystem,
   24                      AttrVolLabel, AttrDirectory, AttrArchive);
   25         AttributeSet = SET OF Attribute;
   26   
   27   FUNCTION RetCode: byte;  external;
   28   
   29   
   30       { -- DOS interrupt and general interrupt procedures -- }
   31   
   32   TYPE  IntRegSpec = RECORD
   33                        zf,cf: Boolean;    {flags returned}
   34                        bp,si,di,ds,es: word;
   35                        CASE Boolean OF
   36                          true:  (ax,bx,cx,dx: word);
   37                          false: (al,ah,bl,bh,cl,ch,dl,dh: byte);
   38                      END;
   39   
   40   PROCEDURE Sys1 (VAR Regs: IntRegSpec);  external;
   41   PROCEDURE SysCall (IntNum: byte; VAR Regs: IntRegSpec);  external;
   42   
   43   
