  571                     name:     butstr;  { filename }
  572                     schema:   shtptr;  { schematic sheet }
  573                     symbol:   shtptr;  { symbol sheet }
  574                     layout:   shtptr;  { layout sheet }
  575                     simulate: shtptr;  { simulate sheet }
  576                     ref:      boolean; { used during external loads }
  577                     cross:    celptr;  { used during external loads }
  578                     next:     celptr   { next entry }
  579   
  580                  end;
  581        csvptr = ^csvrec; { cell save record pointer }
  582        csvrec = record { cell save record }
  583   
  584                    cp: celptr; { cell }
  585                    next: csvptr { next }
  586   
  587                 end;
  588        busety = record { bus entry }
  589   
  590                    name: butstr;  { bus name }
  591                    tmp:  boolean; { bus name is a temp }
  592                    nl:   nodptr;  { nodes chain pointer }
  593                    bl:   drwptr;  { bus lines pointer }
  594                    sl:   busptr;  { used for bus smashing }
  595                    next: busptr   { next entry }
  596   
  597                 end;
  598        nodety = record { node entry }
  599   
  600                    name: butstr;  { node name }
  601                    nord: byte;    { node ordinal }
  602                    tmp:  boolean; { node name is a temp }
  603                    nl:   drwptr;  { first wire in node set }
  604                    sl:   nodptr;  { used for node smashing }
  605                    bl:   nodptr;  { bus membership linkage }
  606                    bh:   busptr;  { bus entry head }
  607                    next: nodptr   { next node in list }
  608   
  609                 end;
  610        { note that there are 16 states of a node, the
  611          perfect number for table lookups. They are
  612          also broken evenly into indeterminate and
  613          determinate states. }
  614        nodest  = (         { node states }
  615        { indeterminate }
  616                   nsundef,   { unspecified }
  617                   nsindet,   { stored indeterminate }
  618                   nsindrh,   { indeterminate driven by high }
  619                   nsindrl,   { indeterminate driven by low }
  620                   nswidh,    { weak indeterminate driven by high }
  621                   nswidl,    { weak indeterminate driven by low }
  622                   nscont,    { conflicting drives }
  623                   nswcont,   { conflicting weak drives }
  624        { determinate }
  625                   nshigh,    { driven high }
  626                   nslow,     { driven low }
  627                   nsstrh,    { stored high }
  628                   nsstrl,    { stored low }
  629                   nswhigh,   { weak driven high }
  630                   nswlow,    { weak driven low }
  631                   nsvdd,     { high supply rail }
  632                   nsvss      { low supply rail }
  633                   );
  634        trcptr = ^trcrec; { pointer to trace record }
  635        trcrec = record { trace record }
  636   
  637                    time:  integer; { time of assertion }
  638                    state: nodest;  { state of assertion }
  639                    next:  trcptr   { next entry }
  640   
  641                 end;
  642        drwety = record { drawing entry }
  643                    
  644                    cl:     color;   { color }
  645                    rm:     rotmod;  { rotation mode }
  646                    next:   drwptr;   { next entry }
  647                    case typ: figtyp of { figure type }
  648   
  649                       tend:      ();
  650                       tline, 
  651                       tbline:    (l:  region); { line }
  652                       tbox, 
  653                       tbbox,
  654                       tmet1,
  655                       tmet2,
  656                       tpoly,
  657                       tvia,
  658                       tndiff,
  659                       tpdiff,
  660                       tnwell,
  661                       tpwell,
  662                       tccut:     (b:  region); { rectangle }
  663                       tinter:    ( { intersection }
  664   
  665                          ir: region;  { region }
  666                          itt: figtyp; { type of top layer }
  667                          ipt: drwptr; { pointer to top layer }
  668                          itb: figtyp; { type of bottom layer }
  669                          ipb: drwptr  { pointer to bottom layer }
  670   
  671                       );
  672                       tarc:      (a:  sarc);   { arc/circle }
  673                       tchar:     (c:  chars);  { character string }
  674                       tbus:      (bs: busfig); { bus }
  675                       tcell:     (cr: celref); { subcell reference }
  676                       tnmos, 
  677                       tpmos, 
  678                       tcap, 
  679                       tres, 
  680                       tdiode, 
  681                       tvdd, 
  682                       tvss:      (o:  point); { fixed cell origin }
  683                       twire,
  684                       tjunction,
  685                       tconnect:  ( { node list types }
  686   
  687                          nl: drwptr; { list link for wires in node }
  688                          nh: nodptr;  { link to attached node }
  689                          case figtyp of { node entries }
  690   
  691                             tend, tline, tbox, tarc, tchar, tbus, 
  692                             tbline, tbbox, tcell, tnmos, tpmos, tcap, 
  693                             tres, tdiode, tvdd, tvss: ();
  694                             twire: (w: region);
  695                             tjunction,
  696                             tconnect: (j: point)
  697   
  698                          { end }
  699   
  700                       );
  701                       ttrc: ( { trace list }
  702   
  703                          ts: point; { start location of trace }
  704                          tl: trcptr { trace list }
  705   
  706                       )
  707   
  708                    { end }
  709   
  710                 end;
  711        namrec = record { name/ordinal save entry }
  712   
  713                    name: butstr;  { name }
  714                    nord: byte;    { ordinal }
  715                    tmp:  boolean; { is a temp }
  716                    next: namptr   { next entry }
  717   
  718                 end;
  719        { printer output buffer }
  720        prtarr = array [0..pbxmax, 0..pbymax] of color;
  721        prtrec = record { printer parameter save record }
  722   
  723                    mx:  rpoint; { maximum }
  724                    off: rpoint; { offset }
  725                    a:   boolean { active flag }
  726   
  727                 end;
  728        prtinx = 1..prtmax; { index for viewer array }
  729        ptrarr = array [prtinx] of prtrec;
  730        { Puck control section.
  731          The puck control record contains all the data 
  732          required to determine the complete puck status.
  733          It is updated each time the tablet is queryed.
  734          The current location of the puck, its valid/invalid
  735          status (puck in proimity of tablet), and the status
  736          of all puck buttons is kept. In addition, serveral
  737          communications flags are kept, which are set by the
  738          puck routine, and cleared only by external software.
  739          These flags indicate puck movement, button assertion,
  740          button deassertion, button drag, and the puck location
  741          at assertion or deassertion. }
  742        pckbut = record { puck button control record }
  743   
  744                    s:  boolean; { current switch close status }
  745                    l:  boolean; { last switch close status }
  746                    a:  boolean; { assertion flag (CMF) }
  747                    d:  boolean; { deassertion flag (CMF) }
  748                    dg: boolean; { drag flag }
  749                    ap: wpoint; { assertion location }
  750                    dp: wpoint  { deassertion location }
  751   
  752                 end;
  753        pckinx = 1..4; { index for puck buttons }
  754        pckctl = record { puck control record }
  755   
  756                    b:  array [pckinx] of pckbut; { puck buttons }
  757                    cl: wpoint; { current location of puck }
  758                    ol: wpoint; { last location of puck }
  759                    m:  boolean; { puck movement flag (CMF) }
  760                    v:  boolean  { puck valid flag }
  761   
  762                 end;
  763        { device errors }
  764        devcod = (deptr); 
  765        bytfil = file of byte; { byte file }
  766   
  767   var irs: intregspec; { dos call record }
  768   
  769   procedure iniscn; external; { initialize display hardware }
  770   procedure resscn; external; { restore display hardware }
  771   procedure setpix(x, y: word; c: color); external; { set pixel value }
  772   
  773   procedure box(xs, ys, xe, ye: word; c: color);
  774   
  775   var x, y: word;
  776   
  777 + begin
  778 + 
  779 *    for x := xs to xe do setpix(x,  ys, c);
  780 *    for x := xs to xe do setpix(x,  ye, c);
  781 *    for y := ys to ye do setpix(xs, y,  c);
  782 *    for y := ys to ye do setpix(xe, y,  c)
  783 + 
  784 + end;
  785 + 
  786   procedure testmod(xm, ym: word);
  787   
  788   var i: word;
  789       c: color;
  790       xs, ys, xe, ye: word;
  791       sp: word;
  792       ch: char;
  793   
  794 + begin
  795 + 
  796 *    sp := (ym div 2) div 16;
  797 *    c := white;
  798 *    xs := 0;
  799 *    ys := 0;
  800 *    xe := xm-1;
  801 *    ye := ym-1;
  802 *    for i := 1 to 15 do begin
  803 + 
  804 *       box(xs, ys, xe, ye, c);
  805 *       xs := xs + sp;
  806 *       ys := ys + sp;
  807 *       xe := xe - sp;
  808 *       ye := ye - sp;
  809 *       c := pred(c)
  810 + 
  811 +    end;
  812 *    while not cstat do;
  813 *    ch := consilent
  814 + 
  815 + end;
  816 + 
  817 + begin
  818 + 
  819 *   iniscn;
  820 *   testmod(1024, 768);
  821 *   resscn;
  822 + 
  823 * end.
