  526                   ltisply, { poly intersections layer }
  527                   ltmet2,  { metal 2 layer }
  528                   ltcont,  { contact layer }
  529                   ltpmd,   { poly, metals and diff layer }
  530                   ltwell); { wells layer }
  531        laylst  = array [laytyp] of drwptr; { layers pointer array }
  532        blkinx  = 1..blkmax; { index for block array }
