   windtbl[vdd,   low   ].drain  := low;
   windtbl[vdd,   strh  ].source := vdd;
   windtbl[vdd,   strh  ].drain  := widh;
   windtbl[vdd,   strl  ].source := vdd;
   windtbl[vdd,   strl  ].drain  := widh;
   windtbl[vdd,   whigh ].source := vdd;
   windtbl[vdd,   whigh ].drain  := whigh;
   windtbl[vdd,   wlow  ].source := vdd;
   windtbl[vdd,   wlow  ].drain  := wcont;
   windtbl[vdd,   vdd   ].source := vdd;
   windtbl[vdd,   vdd   ].drain  := vdd;
   windtbl[vdd,   vss   ].source := vdd;
   windtbl[vdd,   vss   ].drain  := vss;

   windtbl[vss,   undef ].source := vss;
   windtbl[vss,   undef ].drain  := widl;
   windtbl[vss,   indet ].source := vss;
   windtbl[vss,   indet ].drain  := widl;
   windtbl[vss,   indrh ].source := vss;
   windtbl[vss,   indrh ].drain  := indrh;
   windtbl[vss,   indrl ].source := vss;
   windtbl[vss,   indrl ].drain  := indrl;
   windtbl[vss,   widh  ].source := vss;
   windtbl[vss,   widh  ].drain  := wcont;
   windtbl[vss,   widl  ].source := vss;
   windtbl[vss,   widl  ].drain  := widl;
   windtbl[vss,   cont  ].source := vss;
   windtbl[vss,   cont  ].drain  := cont;
   windtbl[vss,   wcont ].source := vss;
   windtbl[vss,   wcont ].drain  := wcont;
   windtbl[vss,   high  ].source := vss;
   windtbl[vss,   high  ].drain  := high;
   windtbl[vss,   low   ].source := vss;
   windtbl[vss,   low   ].drain  := low;
   windtbl[vss,   strh  ].source := vss;
   windtbl[vss,   strh  ].drain  := widl;
   windtbl[vss,   strl  ].source := vss;
   windtbl[vss,   strl  ].drain  := widl;
   windtbl[vss,   whigh ].source := vss;
   windtbl[vss,   whigh ].drain  := wcont;
   windtbl[vss,   wlow  ].source := vss;
   windtbl[vss,   wlow  ].drain  := wlow;
   windtbl[vss,   vdd   ].source := vss;
   windtbl[vss,   vdd   ].drain  := vdd;
   windtbl[vss,   vss   ].source := vss;
   windtbl[vss,   vss   ].drain  := vss

end;

{**************************************************************

Add extention

Adds the extention to the filename. If an extention is already
present, this is left alone.

**************************************************************}

procedure addext(var w: nodlab;  { filename }
                     e: nodlab); { extention }

var i1, i2: labinx; { indexes for labels }

begin

   i1 := 1; { index start of filename }
   { skip to first '.' or space }
   while (i1 < labmax) and (w[i1] <> '.') and
         (w[i1] <> ' ') do i1 := i1 + 1;
   if w[i1] <> '.' then begin { no extention present }

      if w[i1] = ' ' then begin { plant extention }

         i2 := 1; { set 1st extention }
         while i1 <= labmax do begin

            w[i1] := e[i2]; { place character }
            i1 := i1 + 1; { next characters }
            i2 := i2 + 1

         end;
         if i2 < labmax then
            if e[i2] <> ' ' then error(elabtl) { error }

      end

   end

end;

{**************************************************************

Read input line

Reads a line of text from the given text file into the
command buffer. No interactive processing is implemented.

**************************************************************}

procedure readline(var f: text); { input file }

var i : lininx; { index for line }

begin

   for i := 1 to linmax do cmdlin[i] := ' '; { clear command line }
   i := 1; { set 1st character position }
   while not eoln(f) do begin { read characters }

      if i > linmax then error(eilovf); { process error }
      read(f, cmdlin[i]); { get a character }
      i := i + 1 { next character position }

   end;
   readln(f); { skip line end }
   cmdptr := 1 { set 1st character position }

end;

{**************************************************************

Check character

Returns the character at the current command line position.
If the position is off the end of the line, a blank is returned
instead.

**************************************************************}

function chkchr: char;

var c : char;

begin

   { return contents of at line }
   if cmdptr <= linmax then c := cmdlin[cmdptr]
   else c := ' '; { off end, return zip }
   chkchr := c { return result }

end;

{**************************************************************

Get character

Skips to the next command line character. This will only
occur if we are not at the end of the line.

**************************************************************}

procedure getchr;

begin

   if cmdptr <= linmax then cmdptr := cmdptr + 1 { advance }

end;

{**************************************************************

Skip spaces

Skips spaces in the command line. If at line end, we stop.

***************************************************************}

procedure skpspc;

begin

   while (chkchr = ' ') and (cmdptr <= linmax) do
      getchr

end;

{**************************************************************

Get word

Gets a word from the command line. This will be any sequence
of non-space characters after any leading spaces, and
terminated by a space.
Generates an error on label overflow or no word found.

***************************************************************}

procedure getword(var n: nodlab);

var i : labinx; { index for label }

begin

   n := '                    ';
   skpspc; { skip spaces }
   i := 1; { initalize label pointer }
   while (chkchr <> ' ') and (chkchr <> '!') do begin

      if i > labmax then error(elabtl); { process error }
      n[i] := chkchr; { place character }
      i := i + 1; { next character }
      getchr { next character }

   end;
   { convert to lower case }
   for i := 1 to labmax do n[i] := lcase(n[i]);
   if n = '                    ' then error(ecfns) { no word found }

end;

{**************************************************************

Process caller line

Read a line from the given file, and processes the circuit
file there and any command line options.

**************************************************************}

procedure prcopt(var f: text);

begin

   readline(f); { load command line }
   skpspc; { skip spaces }
   if cmdptr > linmax then error(ecfns); { error }
   getword(netnam); { get the circuit file name }
   skpspc; { skip spaces }
   while cmdptr <= linmax do begin { process options }

      if chkchr <> '#' then error(eivopt); { error }
      getchr;
      if not (lcase(chkchr) in ['v', 'd', 'e']) then
         error(eivopt); { error }
      case lcase(chkchr) of { option }

         'v': begin { set verbose mode }

                 fverb := true; { set }
                 getchr { skip }

              end;

         'd': begin { set data mode }

                 fdata := true; { set }
                 getchr { skip }

              end;

         'e': begin { set eval mode }

                 feval := true; { set }
                 getchr { skip }

              end

      end;
      skpspc { skip spaces }

   end

end;

{**************************************************************

Create new node entry

Creates a new node entry by the given number, and returns
a pointer to it.
If the number matches an entry already present, that is returned,
else a new entry is created.
If the new entry is not contingious with the entries
present, the table is filled until it is. Herein lies
the importance of a continigous node numbering system.
Both the next and last states are set to undefined.
The node is placed into the list in alphabetical order.

**************************************************************}

procedure newnode(n: integer;  { label for node }
                  var p: nodptr); { create new node }

var l: nodptr; { node index }
    c: integer; { node counter }
    f: boolean; { found flag }

begin

   p := nodtbl; { index node root }
   l := nil; { clear last }
   c := 0; { set node number count }
   f := false; { set not found }
   while (p <> nil) and not f do begin { search }

      if c = n then f := true { found }
      else begin

         c := c + 1; { count }
         l := p; { set last }
         p := p^.next { next }

      end

   end;
   if not f then repeat { insert }

         new(p); { get new node entry }
         p^.statel := undef;   { set undefined }
         p^.staten := undef;
         p^.trc    := false;   { set not traced }
         p^.num    := c;       { place node number }
         p^.next   := nil;     { link to next }
         if l <> nil then l^.next := p { link last to us }
         else nodtbl := p; { link root to us }
         l := p; { set that as last }
         c := c + 1 { count that entry }

   until c > n

end;

{**************************************************************

Create new transistor

Creates a new transistor of the given type.
Accepts node labels for source, gate and drain, and connects
the transistor to these.

**************************************************************}

procedure newtrans(t: trntyp;            { type of transistor }
                   s, g, d: integer); { nodes }

var f: fetptr; { pointer to fet }
    n: nodptr; { pointer to node }

begin

   new(f); { get a new transistor entry }
   f^.sdg   := f; { clear all }
   f^.gg    := f;
   f^.gr    := nil;
   f^.head  := nil;
   f^.lastc := f;
   f^.nextc := f;
   f^.typet  := t;      { set type }
   newnode(s, n);       { get a source node }
   f^.source := n;      { place }
   newnode(g, n);       { get a gate node }
   f^.gate   := n;      { place }
   newnode(d, n);       { get a drain node }
   f^.drain  := n;      { place }
   if lstfet = nil then fettbl := f { link to root }
   else lstfet^.next := f; { link in line }
   f^.next := nil; { clear next }
   lstfet := f; { set last }
   devcnt := devcnt + 1 { count devices }

end;

{**************************************************************

Create set entry

Creates a set entry, with the given clock trigger, node to
set, and the state to set the node to.
The clock given is converted by the clock scaling to the tick
clock. This means that clocks triggered WITHIN a scaled clock
time happen at the start of that clock time.

**************************************************************}

procedure newset(n: integer; { node to set to }
                 c : integer;      { clock to set on }
                 s : nodest);   { state to set }

var p: nodptr;   { node pointer }
    st: setptr; { set pointer }

begin

   new(st); { create a set entry }
   st^.sdg := nil; { clear all }
   st^.gr := nil;
   newnode(n, p); { create a node }
   st^.clk   := c; { place clock }
   st^.nod   := p; { place node pointer }
   st^.state := s; { place state }
   if lstset = nil then settbl := st { link to root }
   else lstset^.next := st; { link in line }
   st^.next := nil; { clear next }
   lstset := st { set last }

end;

{**************************************************************

Load circuit file

Processes a stream of tolkens. Tolken types:

   1. Transistors.
   2. Set entries.
   3. Step set entry.
   4. Output trace selection.

***************************************************************}

procedure loadckt(var f: bytfil);

var t : trntyp; { transistor type }
    clk: integer; { clock holder }
    st: nodest; { state holder }
    s, g, d, n: integer; { node numbers }
    h, l, b: byte;
    np: nodptr;
    c: byte; { tolken code holder }

begin

   repeat { parse tolkens }

      read(f, c); { get next tolken code }
      if c in [1, 2, 3, 4] then begin

         case c of { transistor type }

            1: t := pmos; { strong p }
            2: t := nmos; { strong n }
            3: t := wpmos; { weak p }
            4: t := wnmos  { weak n }

         end;
         read(f, h); { get source }
         read(f, l);
         s := h*256+l;
         read(f, h); { get gate }
         read(f, l);
         g := h*256+l;
         read(f, h); { get drain }
         read(f, l);
         d := h*256+l;
         newtrans(t, s, g, d) { create transistor }

      end else if c = 5 then begin

         { node set command }
         read(f, h); { get node }
         read(f, l);
         n := h*256+l;
         read(f, b); { get node state }
         case b of { state }

            0:  st := undef;
            1:  st := indet;
            2:  st := indrh;
            3:  st := indrl;
            4:  st := widh;
            5:  st := widl;
            6:  st := cont;
            7:  st := wcont;
            8:  st := high;
            9:  st := low;
            10: st := strh;
            11: st := strl;
            12: st := whigh;
            13: st := wlow;
            14: st := vdd;
            15: st := vss

         end;
         read(f, h); { get clock }
         read(f, l);
         clk := h*256+l;
         newset(n, clk, st) { create a clock entry }

      end else if c = 9 then begin { set step count }

         read(f, h); { get count }
         read(f, l);
         stpcnt := h*256+l { place }

      end else if c = 10 then begin { set output traces }

         read(f, b); { get node count }
         while b <> 0 do begin

            read(f, h); { get node }
            read(f, l);
            newnode(h*256+l, np); { find that node }
            np^.trc := true; { set trace active on that node }
            b := b - 1 { count }

         end

      end else if c <> 0 then error(einvnff) { invalid tolken }

   until c = 0 { end of file }

end;
{**************************************************************

Compare nodes

Compares that both the given nodes are equal, and that they
do not point to a node that holds a rail. Used to qualify
groups.

**************************************************************}

function cmpnod(s, d: nodptr): boolean;

begin

   cmpnod := (s = d) and (s^.staten <> vss) and (s^.staten <> vdd)

end;

{**************************************************************

Form source/drain group

Expects the head entry for the group. The device list is
searched forward, and all source/drain matching entries
are placed into the group list.

**************************************************************}

procedure sdgroup(fp: fetptr);

var fi1, fi2, li: fetptr; { index for fets }

begin

   fp^.head := fp; { self-link head }
   fi1 := fp; { copy top }
   li := nil; { set no last }
   while fi1 <> nil do begin { collect runs }

      fi2 := fettbl; { index group head next }
      while fi2 <> nil do begin { search }

         if (cmpnod(fi2^.source, fi1^.source) or { any node matches }
            cmpnod(fi2^.drain,  fi1^.drain) or
            cmpnod(fi2^.source, fi1^.drain) or
            cmpnod(fi2^.drain,  fi1^.source)) and
            (fi2^.sdg = fi2) then begin { add element }

            if li = nil then fp^.sdg := fi2 { place root }
            else li^.sdg := fi2; { place next }
            li := fi2; { place last }
            fi2^.head := fp; { place group head }
            fi2^.sdg := nil { clear next }

         end;
         fi2 := fi2^.next { next global entry }

      end;
      fi1 := fi1^.sdg { next group entry }

   end

end;

{**************************************************************

Form gate group

Expects the head entry for the group. The device list is
searched forward, and all gate matching entries
are placed into the group list.

**************************************************************}

procedure ggroup(fp: fetptr);

var fi1, fi2: fetptr; { index for fets }

begin

   fi1 := fp; { copy top }
   while fi1 <> nil do begin { traverse group }

      fi2 := fettbl; { index table root }
      while fi2 <> nil do begin { traverse global table }

         if (cmpnod(fi2^.gate, fi1^.source) or { any node matches }
            cmpnod(fi2^.gate, fi1^.drain)) and
            (fi2^.gg = fi2) then begin { add element }

            fi2^.gg := fp^.gr; { push onto list }
            fp^.gr := fi2

         end;
         fi2 := fi2^.next { next global entry }

      end;
      fi1 := fi1^.sdg { next group entry }

   end

end;

{**************************************************************

Link set groups

Links the sets to the appropriate source/drain, gate, or null
groups.

**************************************************************}

procedure setgroup(sp: setptr);

var fp, li: fetptr; { fet pointers }

begin

   { first try to find source/gate group }
   fp := fettbl; { index fet root }
   while (fp <> nil) and (sp^.sdg = nil) do begin { traverse }

      if cmpnod(fp^.source, sp^.nod) or { node matches }
         cmpnod(fp^.drain, sp^.nod) then { enter as a group }
            sp^.sdg := fp^.head
      else fp := fp^.next { next entry }

   end;
   if sp^.sdg = nil then begin { not found in source drain group,
                                 must attach to a gate group }

      fp := fettbl; { index fet root }
      li := nil; { set no last }
      while fp <> nil do begin { traverse }

         if cmpnod(fp^.gate, sp^.nod) then begin { a gate found }

            if fp^.gg <> fp then begin

               sp^.gr := fp; { already done }
               fp := nil { flag done }

            end else begin { add list }

               if li = nil then sp^.gr := fp { place root }
               else li^.gg := fp; { place next }
               fp^.gg := nil; { clear next }
               li := fp { place last }

            end

         end;
         if fp <> nil then fp := fp^.next { next entry }

      end

   end

end;

{**************************************************************

Sweep rails

Performs a "rail sweep". We set any rails found into their
nodes at time 0, then proceed into the set data to determine
if those rails remain constant throughout the pattern.

**************************************************************}

procedure sweep;

var sp: setptr; { pointer for sets }

begin

   sp := settbl; { index top of set list }
   while sp <> nil do begin { traverse list }

      { if at 0, and is a rail, set }
      if (sp^.clk = 0) and (sp^.state = vss) or
         (sp^.state = vdd) then sp^.nod^.staten := sp^.state
      else if sp^.state <> sp^.nod^.staten then
         sp^.nod^.staten := undef; { reset to normal }
      sp := sp^.next { next entry }

   end

end;

{**************************************************************

Phase database

Performs the phasing pass. The point of this is to initalize
all the list and other linkages that enable event evaluation.
Constructs the source/drain and gate groups, and connects
the sets.

**************************************************************}

procedure phase;

var fp: fetptr; { fet pointer }
    sp: setptr; { set pointer }

begin

   sweep; { perform rail sweep }
   fp := fettbl; { index fet table top }
   while fp <> nil do begin { traverse list }

      if fp^.head = nil then begin { group }

            sdgroup(fp); { form source/drain group }
            ggroup(fp)   { form gate group }

      end;
      fp := fp^.next { link next }

   end;
   sp := settbl; { index set table }
   while sp <> nil do begin { link up sets }

      setgroup(sp);  { link that }
      sp := sp^.next { next entry }

   end

end;

{**************************************************************

Enter current group

Enters the source/drain group indexed by the head into the
current eval list.

**************************************************************}

procedure entcur(fp: fetptr);

begin

   if odd(clkcnt) then begin { on odd cycle }

      if fp^.nextc = fp then begin { clear entry }

         fp^.nextc := curtbl; { on odd, next is current }
         curtbl := fp { push onto list }

      end

   end else begin { on even cycle }

      if fp^.lastc = fp then begin { clear entry }

         fp^.lastc := curtbl; { on even, last is current }
         curtbl := fp { push onto list }

      end

   end

end;

{**************************************************************

Enter next group

Enters the source/drain group indexed by the head into the
next eval list.

**************************************************************}

procedure entnxt(fp: fetptr);

begin

   if odd(clkcnt) then begin { on odd cycle }

      if fp^.lastc = fp then begin { clear }

         fp^.lastc := nxttbl; { on odd, last is next }
         nxttbl := fp { push onto list }

      end

   end else begin { on even cycle }

      if fp^.nextc = fp then begin { clear }

         fp^.nextc := nxttbl; { on even, next is next }
         nxttbl := fp { push onto list }

      end

   end

end;

{**************************************************************

Process gate linkage

Expects the head entry of a gate list. All groups that
intersect the gate list are entered into the next eval list.
This is done anytime a change propagates into the gate circuit.
Note that no entry will occur of a group if the new gate state
is the same as the last.

**************************************************************}

procedure gatenext(fp: fetptr);

begin

   while fp <> nil do begin { traverse }

      if not (((fp^.gate^.statel in [high, strh, whigh, vdd]) and
               (fp^.gate^.staten in [high, strh, whigh, vdd])) or
              ((fp^.gate^.statel in [low, strl, wlow, vss]) and
               (fp^.gate^.staten in [low, strl, wlow, vss])) or
              ((fp^.gate^.statel in [undef, indet, indrh, indrl,
                                     widh, widl, cont, wcont]) and
               (fp^.gate^.staten in [undef, indet, indrh, indrl,
                                     widh, widl, cont, wcont]))) then
         { high, low or indeterminate sense of gate has changed }
         entnxt(fp^.head); { enter group }
      fp := fp^.gg { next entry }

   end

end;

{**************************************************************

Output changed trace

If the given node has changed from the last cycle, a trace
entry is issued for it.

***************************************************************}

procedure outchg(n: nodptr);

begin

   if (n^.statel <> n^.staten) and n^.trc then begin

      { it has changed, and it is traced }
      write(trcfil, clkcnt div 256); { output clock time }
      write(trcfil, clkcnt mod 256);
      write(trcfil, n^.num div 256); { output node number }
      write(trcfil, n^.num mod 256);
      write(trcfil, ord(n^.staten))  { output new state }

   end

end;

{**************************************************************

Process set node(s)

Examines the current set entry, and if that is scheduled
on the current clock, it is processed.
Processing consists of setting the node to the indicated
state, then if the node is a gate only node, the trace
is output. This is because this node will never enter
into evaluation.
Note: advances the current set pointer past the current
clock entries, and therefore should be the last set
process call.

**************************************************************}

procedure setnodes;

var sp: setptr; { set pointer }

begin

   sp := curset; { index current }
   while sp <> nil do begin { traverse active entries }

      if sp^.clk = clkcnt then begin

         { place node value }
         sp^.nod^.staten := sp^.state;
         if sp^.sdg = nil then outchg(sp^.nod); { output change trace }
         if sp^.gr <> nil then gatenext(sp^.gr); { enter gate group }
         sp := sp^.next; { link next }
         curset := curset^.next

      end else sp := nil { flag end }

   end

end;

{**************************************************************

Set enter

Enters each set that will be processed in the current cycle
to the appropriate lists.

**************************************************************}

procedure setenter;

var sp: setptr; { set pointer }

begin

   sp := curset; { index current }
   while sp <> nil do begin { traverse active entries }

      if sp^.clk = clkcnt then begin

         if sp^.sdg <> nil then entcur(sp^.sdg); { enter group }
         sp := sp^.next { link next }

      end else sp := nil { flag end }

   end

end;

{**************************************************************

Evaluate transistor

The given transistor is "evaluated" using on, indeterminate and
off rules. Returns a flag indicating whether or not the state
of either the source or drain was changed during evaluation.
The "rules" for on and indeterminate are processed via a
state lookup table to determine the next source and drain
from the last one. The rules for "off" are simple: the transistor
behaves as if it was not there, and is therefore skipped.
The rule a transistor uses are determined by the state on the
gate, which is stored from the last run.

***************************************************************}

procedure evalt(p: fetptr; var f: boolean);

procedure eval(p: fetptr; var t: statbl); { evaluate xstr }

var ss, sd: nodest; { state variables }

begin

   ss := p^.source^.staten;
   sd := p^.drain^.staten; { save previous states }
   { find the next source and drain states }
   p^.source^.staten := t[ss, sd].source;
   p^.drain^.staten  := t[ss, sd].drain;
   { check any state change, flag if so }
   if (ss <> p^.source^.staten) or
      (sd <> p^.drain^.staten) then f := true;

   { take data }

   evals := evals + 1; { count evaluations }
   if f then aevals := aevals + 1; { count active evaluations }

   { output evaluations }

   if feval then
      writeln('Time: ', clkcnt:1, ' gate: ', p^.gate^.num:1,
      '(', ord(p^.gate^.statel):1, ') source: ', p^.source^.num:1,
      '(', ord(ss):1, ',', ord(p^.source^.staten):1, ') drain: ',
      p^.drain^.num:1, '(', ord(sd):1, ',', ord(p^.drain^.staten):1,
      ')')

end;

begin

   case p^.typet of

      nmos:  begin { n-channel xstr }

                if p^.gate^.statel in [high, whigh, strh, vdd] then
                   { xstr on }
                   eval(p, ontbl) { evaluate by "on" rules }
                else if p^.gate^.statel in
                   [undef, indet, indrh, indrl,
                    widh, widl, cont, wcont] then
                   { xstr indeterminate }
                   eval(p, indtbl) { evaluate by "indeterminate" rules }

             end;

      pmos:  begin { p-channel xstr }

                if p^.gate^.statel in [low, wlow, strl, vss] then
                   { xstr on }
                   eval(p, ontbl) { evaluate by "on" rules }
                else if p^.gate^.statel in
                   [undef, indet, indrh, indrl,
                    widh, widl, cont, wcont] then
                   { xstr indeterminate }
                   eval(p, indtbl) { evaluate by "indeterminate" rules }

             end;

      wnmos: begin { weak n-channel xstr }

                if p^.gate^.statel in [high, whigh, strh, vdd] then
                   { xstr on }
                   eval(p, wontbl) { evaluate by "on" rules }
                else if p^.gate^.statel in
                   [undef, indet, indrh, indrl,
                    widh, widl, cont, wcont] then
                   { xstr indeterminate }
                   eval(p, windtbl) { evaluate by "indeterminate" rules }

             end;

      wpmos: begin { weak p-channel xstr }

                if p^.gate^.statel in [low, wlow, strl, vss] then
                   { xstr on }
                   eval(p, wontbl) { evaluate by "on" rules }
                else if p^.gate^.statel in
                   [undef, indet, indrh, indrl,
                    widh, widl, cont, wcont] then
                   { xstr indeterminate }
                   eval(p, windtbl) { evaluate by "indeterminate" rules }

                end

   end

end;

{**************************************************************

Output changed traces

Examines all nodes in a group, and outputs tracers for any
nodes that have changed.

***************************************************************}

procedure outtrc(fp: fetptr);

begin

   while fp <> nil do begin { traverse }

      outchg(fp^.source); { output source side }
      outchg(fp^.drain); { output drain side }
      fp := fp^.sdg { next }

   end

end;

{**************************************************************

Convert group to stored states

Converts all nodes processed in a group back to stored.

***************************************************************}

procedure store(fp: fetptr);

begin

   while fp <> nil do begin { traverse }

      fp^.source^.staten := strtbl[fp^.source^.staten]; { do source }
      fp^.drain^.staten := strtbl[fp^.drain^.staten]; { do drain }
      fp := fp^.sdg { next entry }

   end

end;

{**************************************************************

Process save

Saves the state of all source/drain group and gate group nodes
in the current list. These nodes require an old copy for
various reasons.

***************************************************************}

procedure save;

var fp1, fp2: fetptr; { pointer for fets }
    sp: setptr; { set pointer }

begin

   fp1 := curtbl; { index table top }
   while fp1 <> nil do begin { traverse groups }

      fp2 := fp1; { index group }
      while fp2 <> nil do begin { traverse }

         fp2^.source^.statel := fp2^.source^.staten; { save source }
         fp2^.drain^.statel := fp2^.drain^.staten; { save drain }
         fp2^.gate^.statel := fp2^.gate^.staten; { save gate }
         fp2 := fp2^.sdg { next entry }

      end;
      if odd(clkcnt) then fp1 := fp1^.nextc { link next }
      else fp1 := fp1^.lastc

   end;
   sp := curset; { index current set }
   while sp <> nil do begin { traverse active entries }

      if sp^.clk = clkcnt then begin

         sp^.nod^.statel := sp^.nod^.staten; { save old node value }
         sp := sp^.next { link next }

      end else sp := nil { flag end }

   end

end;

{**************************************************************

Bootstrap rails

A side effect of considering the rails to be virtual circuit
breaks is that they are groupless. This fiction works WHILE
the circuit is in operation, but the initial "step" at time
0 is still a legitimate state transistion, and has to be
processed by entering groups as would be if the rails were not
excepted. We must "fake" this event by manually finding all
groups attached to a rail and setting them into the first eval
list.
Note that this will generate a burst of activity to accomplish
power on settle.

***************************************************************}

procedure strap;

var fp: fetptr; { pointer for fets }

begin

   fp := fettbl; { index table start }
   while fp <> nil do begin { traverse }

      if (fp^.source^.staten = vdd) or
         (fp^.source^.staten = vss) or
         (fp^.drain^.staten = vdd) or
         (fp^.drain^.staten = vss) then entcur(fp^.head); { enter }
      if (fp^.gate^.staten = vdd) or
         (fp^.gate^.staten = vss) then entnxt(fp^.head); { enter }
      fp := fp^.next { next entry }

   end

end;

{**************************************************************

Clear nodes

Clears all nodes back to the undefined state.

***************************************************************}

procedure clearnodes;

var np: nodptr;

begin

   np := nodtbl; { index node table }
   while np <> nil do begin { traverse }

      np^.staten := undef; { clear node }
      np := np^.next { next node }

   end

end;

{**************************************************************

Process groups

This procedure, which still retains it's historical name,
performs all transistor evaluation on the net. Each transistor
group is poped off the current list and processed until the
current list is emptied. Each group is evaluated by running
down the group list, evaluating each transistor in the list.
If any changes in node states occurred during this process,
the entire group is evaluated over again until the group
is "relaxed". Theoretically, it is impossible for a group
to fail to relax.
The next step is to run a trace output on the group.
Finally, the gate list for the group is entered into the next
cycle list.
Note that if the next eval list should be null, this indicates
that the net has completely settled. In this case, we can skip
forward in time until the next known event, which would be
the next "set" time. If that list is also empty, the simulation
terminates.

***************************************************************}

procedure sclock;

var gp, fp: fetptr; { group pointers }
    f: boolean; { evaluation change pointer }

begin

   setenter; { enter set groups }
   save; { save active nodes }
   setnodes; { process node sets }
   while curtbl <> nil do begin { evaluate top group }

      gp := curtbl; { index group header }
      { pop top by even/odd sense }
      if odd(clkcnt) then begin

         curtbl := curtbl^.nextc;
         gp^.nextc := gp

      end else begin

         curtbl := curtbl^.lastc;
         gp^.lastc := gp

      end;
      store(gp); { convert loop to stored states }
      repeat { run group evaluation }

         f := false; { set no change }
         fp := gp; { index group top }
         while fp <> nil do begin { process transistors }

            evalt(fp, f); { perform evaluation }
            fp := fp^.sdg { next transistor }

         end

      until not f;
      outtrc(gp); { output any changed traces }
      gatenext(gp^.gr) { enter gates to next }

   end;
   clkcnt := clkcnt + 1; { advance clock }
   curtbl := nxttbl; { set next as current to execute }
   nxttbl := nil; { clear next }
   if curtbl = nil then begin { net has completely settled }

      if curset <> nil then clkcnt := curset^.clk { skip forward }
      else clkcnt := stpcnt { end simulation }

   end

end;

{**************************************************************

Main program

Initalizes global variables, processes the options, loads
the circuit file and runs the simulation.

**************************************************************}

begin

   writeln('CMOS circuit simulator 0.1 Copyright (C) 1988 S. A. Moore');

   { initalize "on" state tables }

   initon;
   initwon;

   { initalize "indeterminate" state table }

   initind;
   initwind;

   { set start of clock translation table }

   strtbl[undef] := undef; { stays }
   strtbl[indet] := indet; { stays }
   strtbl[indrh] := indet; { goes to general stored }
   strtbl[indrl] := indet; { "   " }
   strtbl[widh]  := indet; { "   " }
   strtbl[widl]  := indet; { "   " }
   strtbl[cont]  := indet; { "   " }
   strtbl[wcont] := indet; { "   " }
   strtbl[high]  := strh;  { goes to stored }
   strtbl[low]   := strl;  { goes to stored }
   strtbl[strh]  := strh;  { stays }
   strtbl[strl]  := strl;  { stays }
   strtbl[whigh] := strh;  { goes to stored }
   strtbl[wlow]  := strl;  { "   " }
   strtbl[vdd]   := vdd;   { stays }
   strtbl[vss]   := vss;   { stays }

   { initalize tables }

   nodtbl := nil;
   fettbl := nil;
   settbl := nil;
   curtbl := nil;
   nxttbl := nil;
   lstfet := nil;
   lstset := nil;
   clkcnt := 0; { set clock time 0 }
   stpcnt := 0; { set no step }
   fverb := false; { set no verbose }
   fdata := false; { set no data }
   feval := false; { set no evals }
   devcnt := 0; { clear device count }
   netopn := false; { net file open }
   setopn := false; { set file open }
   trcopn :  false; { trace file open }

   { process options and open output file }

   prcopt(command); { process options }
   setnam := netnam; { copy names }
   trcnam := netnam;
   addext(netnam, '.sim                '); { place extentions }
   addext(setnam, '.set                ');
   addext(trcnam, '.trc                ');
   { check circuit files exist }
   if not exists(netnam) then error(ecfnf);
   if not exists(setnam) then error(ecfnf);
   assign(netfil, netnam); { open net file }
   reset(netfil);
   netopn := true;
   assign(setfil, setnam); { open set file }
   reset(netfil);
   setopn := true;
   assign(trcfil, trcnam); { open trace file }
   rewrite(trcfil);
   trcopn := true;

   { load files }

   loadckt(netfil);
   loadckt(setfil);
   phase; { run phasing pass }
   curset := settbl; { index first set entry }
   strap; { bootstrap rails }
   clearnodes; { clear nodes }

   { run simulation }

   if fverb then writeln('Executing simulation');
   if fdata then writeln('Device count: ', devcnt:1);
   while clkcnt < stpcnt do begin { run sim }

      evals := 0; { clear eval stats }
      aevals := 0; { clear active evals }
      sclock; { run clock cycle }
      if fdata then writeln('Time: ', clkcnt:1, ' total evaluations: ',
                            evals:1, ' active evaluations: ', aevals)

   end;
   write(trcfil, $ff, $ff); { terminate trace file }

   99: { abort program }

   if fverb then writeln('Function complete');
   close(netfil); { close files }
   close(setfil);
   close(trcfil)

end.
