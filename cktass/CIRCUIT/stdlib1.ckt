{**************************************************************

And gate

Provides the "and" function for two inputs.

Transistors: 4

**************************************************************}

cell and: vss, vdd, input1, input2, output;

begin

   nand: vss, vdd, input1, input2, n1;
   inv:  vss, vdd, n1, output

end;

