{ Xor gate, using transmision gates }

cell xor: vss, vdd, input1, input2, output;

begin

   inv: vss, vdd, input1, n1; { invert both inputs }
   inv: vss, vdd, input2, n2;
   tg:  input2, output, n1, input1; { perform xor }
   tg:  n2,     output, input1, n1

end;

{ Xor gate, using standard gates }

cell xor1: vss, vdd, input1, input2, output;

begin

   inv:  vss, vdd, input1,  n1;
   inv:  vss, vdd, input2,  n2;
   nand: vss, vdd, input2,  n1, n3;
   nand: vss, vdd, input1,  n2, n4;
   nand: vss, vdd, n3,      n4, output

end;
