{**************************************************************
*                                                             *
*                   STANDARD LIBRARY                          *
*                                                             *
* This file contains the definitions for most common circuits *
* of interest, with variations for functions and number of    *
* transistors. Each definition may include a subdefinition    *
* that appears earlier in the file.                           *
* Note that it is impractical to use the entire file. To      *
* create a new circuit, a specially editted version would     *
* usually be made.                                            *
*                                                             *
* External node definitions:                                  *
*                                                             *
*     vdd - +5 or power.                                      *
*     vss - 0 or ground.                                      *
*                                                             *
**************************************************************}

{**************************************************************

Inverter

Provides a true output on false input, and vice-versa.

Transistors: 2

**************************************************************}

cell inv: vss, vdd, input, output_;

begin

   peif: vdd, input, output_;
   neif: vss, input, output_

end;

{**************************************************************

Transmision gate

Connects the terminals together when the enable is
true, else provides high impedence between them.
Has no drive capabillity of it's own.

Transistors: 2

**************************************************************}

cell tg: left, right, enable, enable_; { no particular direction here }

begin

   peif: left, enable_, right;
   neif: left, enable, right

end;

{**************************************************************

Buffered positive transmision gate

As a normal transmission gate, but only requires
a single positive enable.
Due to the inverter delay, the circuit has a built-in
effect that causes it to turn on partially during
a short period after switching.

Transistors: 4

**************************************************************}

cell tgb: vss, vdd, left, right, enable;

begin

   inv: vss, vdd, enable, enable_; { form inverted clock }
   tg:  left, right, enable, enable_ { use positive transmision gate }

end;

{**************************************************************

Buffered negative transmision gate

As a buffered positive transmition gate, but uses
a negative enable.

Transistors: 4

**************************************************************}

cell tgbn: vss, vdd, left, right, enable_;

begin

   inv: vss, vdd, enable_, enable; { form inverted clock }
   { use negative transmission gate }
   tg: left, right, enable_, enable

end;

{**************************************************************

Nand gate

Provides the "nand" function for two inputs.

Transistors: 4

**************************************************************}

cell nand: vss, vdd, input1, input2, output_;

begin

  peif: vdd, input1, output_;
  peif: vdd, input2, output_;
  neif: vss, input1, n1;
  neif: n1,  input2, output_

end;

{**************************************************************

Three input nand gate

Provides the "nand" function for Three inputs.

Transistors: 6

**************************************************************}

cell nand3: vss, vdd, input1, input2, input3, output_;

begin

   peif: vdd, input1, output_;
   peif: vdd, input2, output_;
   peif: vdd, input3, output_;
   neif: vss, input1, n1;
   neif: n1,  input2, n2;
   neif: n2,  input3, output_

end;

{**************************************************************

Four input nand gate

Provides the "nand" function for Four inputs.

Transistors: 8

**************************************************************}

cell nand4: vss, vdd, input1, input2, input3, input4, output_;

begin

   peif: vdd, input1, output_;
   peif: vdd, input2, output_;
   peif: vdd, input3, output_;
   peif: vdd, input4, output_;
   neif: vss, input1, n1;
   neif: n1,  input2, n2;
   neif: n2,  input3, n3;
   neif: n3,  input4, output_

end;

{**************************************************************

Five input nand gate

Provides the "nand" function for Five inputs.

Transistors: 10

**************************************************************}

cell nand5: vss, vdd, input1, input2, input3, input4, input5, output_;

begin

