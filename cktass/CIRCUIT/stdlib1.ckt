end;

{**************************************************************

Eight input nand gate

Provides the "nand" function for eight inputs.
Eight inputs is about the maximum inputs possible for
a reliable gate.

Transistors: 16

**************************************************************}

cell nand8: vss, vdd, input1, input2, input3, input4, input5, input6,
            input7, input8, output_;

begin

   peif: vdd, input1, output_;
   peif: vdd, input2, output_;
   peif: vdd, input3, output_;
   peif: vdd, input4, output_;
   peif: vdd, input5, output_;
   peif: vdd, input6, output_;
   peif: vdd, input7, output_;
   peif: vdd, input8, output_;
   neif: vss, input1, n1;
   neif: n1, input2, n2;
   neif: n2, input3, n3;
   neif: n3, input4, n4;
   neif: n4, input5, n5;
   neif: n5, input6, n6;
   neif: n6, input7, n7;
   neif: n7, input8, output_

end;

{**************************************************************

Nor gate

Provides the "nor" function for two inputs.
Note that the nor is theoretically slower than
a nand because of the p stack, and therefore
the nand is preferred.

Transistors: 4

**************************************************************}

cell nor: vss, vdd, input1, input2, output_;

begin

   peif: vdd, input1, n1;
   peif: n1,  input2, output_;
   neif: vss, input1, output_;
   neif: vss, input2, output_

end;

{**************************************************************

Three input nor gate

Provides the "nor" function for three inputs.

Transistors: 6

**************************************************************}

cell nor3: vss, vdd, input1, input2, input3, output_;

begin

   peif: vdd, input1, n1;
   peif: n1, input2, n2;
   peif: n2, input3, output_;
   neif: vss, input1, output_;
   neif: vss, input2, output_;
   neif: vss, input3, output_

end;

