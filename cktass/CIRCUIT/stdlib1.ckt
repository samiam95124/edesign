   peif: vdd, input2, output_;
   peif: vdd, input3, output_;
   peif: vdd, input4, output_;
   peif: vdd, input5, output_;
   neif: vss, input1, n1;
   neif: n1, input2, n2;
   neif: n2, input3, n3;
   neif: n3, input4, n4;
   neif: n4, input5, output_

end;

